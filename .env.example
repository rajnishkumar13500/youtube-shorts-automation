# YouTube Shorts Automation - Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API Key (for script generation using OSS models)
# Get your free API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs API Keys (for voice generation)
# Primary token - REQUIRED
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Fallback tokens - OPTIONAL (for automatic failover when quota exceeded)
# Add multiple free accounts to extend your quota
ELEVENLABS_API_KEY_2=your_second_elevenlabs_key_here
ELEVENLABS_API_KEY_3=your_third_elevenlabs_key_here
# Add more as needed: ELEVENLABS_API_KEY_4, ELEVENLABS_API_KEY_5, etc.

# Cloudflare AI credentials (for image generation)
# Get from: https://dash.cloudflare.com/ -> AI -> Workers AI
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Google Sheets Integration (for automation)
# Path to service account JSON credentials file
GOOGLE_SHEETS_CREDENTIALS=google_sheets_credentials.json
# Your Google Sheets spreadsheet ID (from the URL)
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# YouTube Upload Integration (for automation)
# Path to OAuth2 client secrets JSON file
YOUTUBE_CLIENT_SECRETS=youtube_client_secrets.json

# Optional: Background Music Settings
DEFAULT_BG_MUSIC_PATH=path/to/background/music.mp3
ENABLE_BG_MUSIC=false
