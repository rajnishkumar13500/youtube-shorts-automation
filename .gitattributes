# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Markdown files
*.md text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# JSON files
*.json text eol=lf

# Environment files
.env* text eol=lf

# Binary files
*.mp4 binary
*.mp3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.pickle binary
